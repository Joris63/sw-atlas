{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Extra safety for array and object lookups.
    "noUncheckedIndexedAccess": true,
    // Functions must explicitly return on every branch.
    "noImplicitReturns": true,
    // Prevents accidental fallthrough in switch statements.
    "noFallthroughCasesInSwitch": true,
    // Forces `override` keyword — avoids silent breakage when base class changes.
    "noImplicitOverride": true,
    // Catches unused local variables and parameters (parameters: only after last used).
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // Consistent file casing across OS boundaries.
    "forceConsistentCasingInFileNames": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
